{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base",
    ":dependencyDashboard"
  ],
  "packageRules": [
    {
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true,
      "automergeType": "branch",
      "ignoreTests": false
    }
  ],
  "pep621": {
    "fileMatch": ["(^|/)pyproject\\.toml$"]
  }
}
